" basics
syntax on
set number
set cursorline
set autoindent

" autowrap with arrow keys
set whichwrap+=<,>,h,l

" status bar
set laststatus=2
set statusline=%f\ %h%m%r\ %=Line\:%l,\ Col\:%c

" stop the bell
set belloff=all

" stop cursor from moving when holding backspace in command mode
cnoremap <expr> <BS> strlen(getcmdline()) ? "\<BS>" : ""

" theme
hi clear
hi Comment ctermfg=2
hi Constant ctermfg=3
hi Statement ctermfg=3
hi StatusLine ctermbg=3 ctermfg=237
hi CursorLine gui=NONE guisp=NONE cterm=NONE ctermfg=NONE ctermbg=237
hi CursorLineNr guifg=NONE guibg=NONE ctermfg=8 ctermbg=3 cterm=NONE
hi Todo ctermbg=NONE ctermfg=3
hi TabLineFill ctermfg=237
hi TabLine ctermfg=NONE ctermbg=NONE gui=NONE guisp=NONE cterm=NONE
hi TabLineSel ctermfg=3 ctermbg=8 gui=NONE guisp=NONE cterm=NONE

" set to 4 tabs
set noexpandtab
set tabstop=4
set shiftwidth=4

